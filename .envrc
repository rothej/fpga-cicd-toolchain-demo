#!/bin/bash
# .envrc - Environment setup for fpga-cicd-toolchain-demo

layout python python3.12

export PYTHONPATH="${PWD}/tb:${PYTHONPATH}"

# Add Verible tools to PATH (after running scripts/setup_verible.sh)
if [ -d ".tools/verible/bin" ]; then
    PATH_add ".tools/verible/bin"
fi

# Add Verilator to PATH if installed locally
if [ -d ".tools/verilator/bin" ]; then
    PATH_add ".tools/verilator/bin"
fi

alias pytest='python -m pytest'

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "SV Toolchain Demo Environment"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Python:  $(python --version) @ $(which python)"
if command -v verible-verilog-lint &> /dev/null; then
    echo "  Verible: $(verible-verilog-lint --version 2>&1 | head -1)"
else
    echo "  Verible: Not installed (run ./scripts/setup_verible.sh)"
fi
if command -v verilator &> /dev/null; then
    echo "  Verilator: $(verilator --version | head -1)"
else
    echo "  Verilator: Not found"
fi
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
